{#
/**
 * Accordion hero block template for a Drupal 11 Bootstrap Barrio subtheme.
 *
 * Rename this file to the exact block template suggestion generated by Drupal,
 * for example block--hero-accordion.html.twig, then clear cache.
 */
#}
{{ attach_library('cesasc_theme/accordion-hero') }}

<section class="accordion-hero accordion-hero--full-bleed js-accordion-hero" aria-label="{{ 'Featured sections'|t }}">
  <article class="accordion-hero__item is-active" style="--hero-image: url('/{{ base_path ~ directory }}/images/accordion-hero/science.jpeg');">
    <button class="accordion-hero__trigger" type="button" aria-expanded="true" aria-controls="accordion-hero-panel-home">
      <span class="accordion-hero__number">01</span>
      <span class="accordion-hero__title">{{ 'Science'|t }}</span>
    </button>
    <div class="accordion-hero__panel" id="accordion-hero-panel-home" aria-hidden="false">
      <p>{{ 'Science helps us understand the future.'|t }}</p>
      <a class="btn btn-light btn-sm" href="/">{{ 'Explore'|t }}</a>
    </div>
  </article>

  <article class="accordion-hero__item" style="--hero-image: url('/{{ base_path ~ directory }}/images/accordion-hero/engineering.jpg');">
    <button class="accordion-hero__trigger" type="button" aria-expanded="false" aria-controls="accordion-hero-panel-about">
      <span class="accordion-hero__number">02</span>
      <span class="accordion-hero__title">{{ 'Engineering'|t }}</span>
    </button>
    <div class="accordion-hero__panel" id="accordion-hero-panel-about" aria-hidden="true" inert>
      <p>{{ 'Engineering helps us invent the future.'|t }}</p>
      <a class="btn btn-light btn-sm" href="/about">{{ 'Explore'|t }}</a>
    </div>
  </article>

  <article class="accordion-hero__item" style="--hero-image: url('/{{ base_path ~ directory }}/images/accordion-hero/smart-city.jpg');">
    <button class="accordion-hero__trigger" type="button" aria-expanded="false" aria-controls="accordion-hero-panel-work">
      <span class="accordion-hero__number">03</span>
      <span class="accordion-hero__title">{{ 'Artificial Intelligence'|t }}</span>
    </button>
    <div class="accordion-hero__panel" id="accordion-hero-panel-work" aria-hidden="true" inert>
      <p>{{ 'Artificial Intelligence is transforming the way we live and work.'|t }}</p>
      <a class="btn btn-light btn-sm" href="/">{{ 'Explore'|t }}</a>
  </article>

  <article class="accordion-hero__item" style="--hero-image: url('/{{ base_path ~ directory }}/images/accordion-hero/map.jpg');">
    <button class="accordion-hero__trigger" type="button" aria-expanded="false" aria-controls="accordion-hero-panel-contact">
      <span class="accordion-hero__number">04</span>
      <span class="accordion-hero__title">{{ 'Bridging'|t }}</span>
    </button>
    <div class="accordion-hero__panel" id="accordion-hero-panel-contact" aria-hidden="true" inert>
      <p>{{ 'CESASC is a community of innovators dedicated to advancing technology for the betterment of society.'|t }}</p>
      <a class="btn btn-light btn-sm" href="/">{{ 'About us'|t }}</a>
    </div>
  </article>
</section>
